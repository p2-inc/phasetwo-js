{
  "name": "phasetwo-js",
  "version": "0.1.1",
  "description": "Browser library for identity and access management",
  "repository": {
    "type": "git",
    "url": "https://github.com/p2-inc/phasetwo-js.git"
  },
  "private": true,
  "browser": "dist/phasetwo-js.umd.js",
  "main": "dist/phasetwo-js.umd.js",
  "module": "dist/phasetwo-js.es.js",
  "files": [
    "dist"
