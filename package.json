    "@rollup/plugin-commonjs": "^13.0.0",
    "@rollup/plugin-node-resolve": "^7.1.3",
    "babel-plugin-transform-class-properties": "^6.24.1",
    "jest": "^26.0.0",
    "np": "^6.2.3",
    "rollup": "^2.7.2"
  }
